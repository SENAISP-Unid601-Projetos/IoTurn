generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "mysql"
  url      = "mysql://root:123456@localhost:3306/senaizinho2"
}

model Usuario {
  id                Int @id @default(autoincrement())
  nome              String
  cpf               String
  numero            Int
  dataCadastro      DateTime
}
